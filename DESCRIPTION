Package: PhyloAnnotator
Title: Build iTOL Annotations and Phylogenetic Metadata Atlases
Version: 0.1.0
Authors@R: c(
    person("PhyloAnnotator contributors", email = "maintainers@example.org", role = c("aut", "cre"))
